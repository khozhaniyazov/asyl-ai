# Asyl AI - Production Environment Variables
# Copy this file to .env.production and fill in all values

# === REQUIRED ===

# Database
DB_USER=sandar_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=sandar_db

# Security
SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_STRING

# MinIO (S3-compatible storage)
MINIO_USER=sandar_admin
MINIO_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# Domain
FRONTEND_URL=https://app.sandar.kz

# === AI SERVICES (at least one recommended) ===

# Google Gemini (for SOAP note generation)
GEMINI_API_KEY=

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=

# === INTEGRATIONS (optional, mock fallback if empty) ===

# Kaspi Pay Merchant API
KASPI_API_KEY=
KASPI_MERCHANT_ID=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
