# Environment
ENVIRONMENT=development
SECRET_KEY=change-this-in-production-use-long-random-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./asyl_ai.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# WhatsApp Business API (Meta Cloud API)
# Get these from: https://developers.facebook.com/apps/ -> Your App -> WhatsApp -> API Setup
WHATSAPP_API_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Kaspi.kz Payment Integration
KASPI_API_KEY=your_kaspi_api_key_here
KASPI_MERCHANT_ID=your_kaspi_merchant_id_here

# Redis (optional - for rate limiting)
REDIS_URL=redis://localhost:6379/0

# S3/MinIO Storage (optional - for file uploads)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=asyl-ai-uploads
