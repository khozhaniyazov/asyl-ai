# Required for deployment
GEMINI_API_KEY=your_gemini_api_key_here

# Auto-generated on Render (for local dev, generate your own)
SECRET_KEY=your_local_secret_key_here

# Database URL (auto-configured on Render)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# MinIO/S3 settings (for local dev only - use Render disk for production)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET_NAME=logoped-sessions
